OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
APP_ENV=production
CORS_ALLOW_ORIGINS=https://YOUR_VERCEL_DOMAIN.vercel.app,https://YOUR_CUSTOM_DOMAIN.com,http://127.0.0.1:8000,http://localhost:8000
EXPOSE_API_DOCS=false
MAX_UPLOAD_BYTES=5242880
# Render 后端需要配置 OPENAI_API_KEY，并把 CORS_ALLOW_ORIGINS 中的 YOUR_VERCEL_DOMAIN 换成真实 Vercel 域名。
# Vercel 前端默认通过 /api/* rewrite 访问 https://find-yourself-api.onrender.com。
# 如果 Render 服务名不同，请同步修改 vercel.json 中的 rewrite 目标。
# For local development, keep CORS_ALLOW_ORIGINS including http://127.0.0.1:8000 and http://localhost:8000.
